<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-12">
            <h2>Create new Feed</h2>
            <form method="post" action="/feed"   class="needs-validation" enctype="multipart/form-data" novalidate>
                <div class="row">
                    <div  class="mb-3 col-md-8">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" name="feed[title]" class="form-control"  placeholder="title" required>
                        <div class="invalid-feedback" >Title is required!</div>
                    </div>
                    <div  class="mb-3 col-md-4">
                        <label for="category" class="form-label">Category</label>
                        <select name="feed[category]" class="form-select"  id="">
                            <option value="motivational">motivational</option>
                            <option value="fitness">fitness</option>
                            <option value="spiritual">spiritual</option>
                            <option value="natural-fact">natural-fact</option>
                        </select>
                    </div>
                </div>    
                <div class="mb-3">
                    <label for="image" class="form-label">Upload Image</label>   
                    <input type="file" name="feed[image]" class="form-control">
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="feed[description]" id="" class="form-control" required placeholder="description"></textarea>
                    <div class="invalid-feedback" >Description is required!</div>
                </div>
                <div class="mb-3">
                    <label for="info" class="form-label">Info</label>
                    <textarea name="feed[info]" id="" class="form-control" required placeholder="info"></textarea>
                    <div class="invalid-feedback" >Info is required!</div>
                </div><br>
                <button id="add" class="btn custom-btn w-100" >Add</button>
            </form>
        </div>
    </div>
    </div>
</body>