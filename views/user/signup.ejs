<% layout("/layouts/boilerplate.ejs") %>
<div class="container py-4">
    <div class="row justify-content-center">
    <div class="col-lg-6 col-md-8 col-12">
        <h2 class=" text-center mb-4">Signup for Morning Tea</h2>
        <div class="card shadow p-4">
        <form action="/user/signup" method="post" novalidate enctype="multipart/form-data" class="needs-validation">
                <div class="mb-3">
                    <label for="username" class="form-label">username</label>   
                    <input type="text" id="username" name="username" class="form-control" required>
                    <div class="invalid-feedback" >username is required!</div>
                    <div class="valid-feedback" >Looks good!</div>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">email</label>   
                    <input type="email" id="email" name="email" class="form-control" required>
                    <div class="invalid-feedback" >email is required!</div>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">password</label>   
                    <input type="password" id="password" name="password" class="form-control" required>
                    <div class="invalid-feedback" >password is required!</div>
                </div>
                <div class="mb-3">
                    <label>Profile Picture</label>
                    <input type="file" name="profileImage" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Preferred Categories</label>
                    <div class="form-check">
                        <input class="form-check-input " type="checkbox" name="preferredCategories" value="motivational">
                        <label class="form-check-label">Motivational</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="preferredCategories" value="fitness">
                        <label class="form-check-label">Fitness</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="preferredCategories" value="natural-fact">
                        <label class="form-check-label">Natural-fact</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="preferredCategories" value="news">
                        <label class="form-check-label">News</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="preferredCategories" value="spiritual">
                        <label class="form-check-label">Spiritual</label>
                    </div>
                </div>
                <button class="btn custom-btn primary-btn w-100" id="signup">Signup</button>
        </form>
        </div>
        <div class="text-center mt-3">
            <a href="/user/login">
                Already have an account? Login
            </a>
        </div>
    </div>
    </div>
</div>