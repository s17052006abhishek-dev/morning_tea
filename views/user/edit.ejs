<% layout("/layouts/boilerplate.ejs") %>
<div class="row mt-3" >
    <h2 class="col-6 offset-3">Edit your Profile</h2>
    <div class="col-6 offset-3">
        <form action="/user/<%= user._id %>?_method=put" method="post" novalidate enctype="multipart/form-data" class="needs-validation">
                <div class="mb-3">
                    <label for="username" class="form-label">username</label>   
                    <input type="text" id="username" name="username" class="form-control" value="<%= user.username %>" required>
                    <div class="invalid-feedback" >username is required!</div>
                    <div class="valid-feedback" >Looks good!</div>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">email</label>   
                    <input type="email" id="email" name="email" class="form-control" value="<%= user.email %>" required>
                    <div class="invalid-feedback" >email is required!</div>
                </div>
                <div>
                    <h4>Current uploaded image</h4>
                    <img style="height: auto; width: 250px;" src="<%= user.profileImage.url %>" alt="feed image">
                </div>
                <div class="mb-3">
                    <label>Profile Picture</label>
                    <input type="file" name="profileImage" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Preferred Categories</label>
                    <div class="form-check">
                        <input <%= user.preferredCategories.includes("motivational") ? "checked" : "" %> class="form-check-input " type="checkbox" name="preferredCategories" value="motivational">
                        <label class="form-check-label">Motivational</label>
                    </div>
                    <div class="form-check">
                        <input <%= user.preferredCategories.includes("fitness") ? "checked" : "" %> class="form-check-input" type="checkbox" name="preferredCategories" value="fitness">
                        <label class="form-check-label">Fitness</label>
                    </div>
                    <div class="form-check">
                        <input <%= user.preferredCategories.includes("natural-fact") ? "checked" : "" %> class="form-check-input" type="checkbox" name="preferredCategories" value="natural-fact">
                        <label class="form-check-label">Natural-fact</label>
                    </div>
                    <div class="form-check">
                        <input <%= user.preferredCategories.includes("news") ? "checked" : "" %> class="form-check-input" type="checkbox" name="preferredCategories" value="news">
                        <label class="form-check-label">News</label>
                    </div>
                    <div class="form-check">
                        <input <%= user.preferredCategories.includes("spiritual") ? "checked" : "" %> class="form-check-input" type="checkbox" name="preferredCategories" value="spiritual">
                        <label class="form-check-label">Spiritual</label>
                    </div>
                </div>
                <button  class="custom-btn btn" id="save" >Save</button>
        </form>
    </div>
</div>